      "title": "Portfolio Notional (USD)",
      "type": "timeseries",
      "targets": [
        { "expr": "trade_portfolio_notional_usd", "legendFormat": "Notional", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
