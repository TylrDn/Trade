      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto" },
      "title": "Daily P&L (USD)",
      "type": "stat",
      "targets": [
        { "expr": "trade_daily_pnl_usd", "legendFormat": "Daily P&L", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "title": "Orders Submitted vs Blocked",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(trade_orders_submitted_total[5m])", "legendFormat": "Submitted", "refId": "A" },
        { "expr": "rate(trade_orders_blocked_total[5m])", "legendFormat": "Blocked", "refId": "B" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "title": "Circuit Breaker Trips",
      "type": "stat",
      "targets": [
        { "expr": "trade_circuit_trips_total", "legendFormat": "Trips", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "currencyUSD" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
