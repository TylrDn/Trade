# ── Environment ──────────────────────────────────────────────
# Values: research | staging | production
TRADE_ENV=research

# ── NautilusTrader ────────────────────────────────────────────
NAUTILUS_LOG_LEVEL=INFO
NAUTILUS_BYPASS_LOGGING=false

# ── Data Catalog ─────────────────────────────────────────────
CATALOG_PATH=./catalog

# ── Binance Adapter ──────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# ── Kraken Adapter ───────────────────────────────────────────
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ── Observability ────────────────────────────────────────────
PROMETHEUS_PORT=8000
LOGFIRE_TOKEN=

# ── Alerting ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=

# ── Risk Limits ──────────────────────────────────────────────
# Maximum daily loss in USD before system halts
RISK_MAX_DAILY_LOSS_USD=500.0
# Maximum single position notional in USD
RISK_MAX_POSITION_NOTIONAL_USD=10000.0
# Maximum portfolio-level leverage
RISK_MAX_LEVERAGE=3.0
# Max open orders at any time
RISK_MAX_OPEN_ORDERS=20
# Stale feed threshold in seconds
RISK_STALE_FEED_SECONDS=30
