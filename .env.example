# ── Environment ──────────────────────────────────────────────
# Values: research | staging | production
TRADE_ENV=research

# ── Venue selection ──────────────────────────────────────────
TRADE_VENUE=kraken
# Optional overrides (empty = venue default instrument/bar type)
TRADE_INSTRUMENT=
TRADE_BAR_TYPE=

# ── NautilusTrader ────────────────────────────────────────────
NAUTILUS_LOG_LEVEL=INFO
NAUTILUS_BYPASS_LOGGING=false

# ── Data Catalog ─────────────────────────────────────────────
CATALOG_PATH=./catalog

# ── Binance Adapter (TRADE_VENUE=binance) ────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# ── Kraken Futures (TRADE_VENUE=kraken) ──────────────────────
KRAKEN_DEMO=true
KRAKEN_FUTURES_DEMO_API_KEY=
KRAKEN_FUTURES_DEMO_API_SECRET=
KRAKEN_FUTURES_API_KEY=
KRAKEN_FUTURES_API_SECRET=

# ── Observability ────────────────────────────────────────────
PROMETHEUS_PORT=8000
LOGFIRE_TOKEN=

# ── Alerting ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=

# ── Risk Limits ──────────────────────────────────────────────
RISK_MAX_DAILY_LOSS_USD=500.0
RISK_MAX_POSITION_NOTIONAL_USD=10000.0
RISK_MAX_PORTFOLIO_NOTIONAL_USD=50000.0
RISK_MAX_LEVERAGE=3.0
RISK_MAX_OPEN_ORDERS=20
RISK_STALE_FEED_SECONDS=30
# Kraken Futures demo: allow 3 min for first INTERNAL bar (low tick rate)
RISK_FEED_STARTUP_GRACE_SECONDS=180

# ── Strategy gating ──────────────────────────────────────────
BLOCK_ENTRIES_UNTIL_REGIME=false

# ── Reconciliation ───────────────────────────────────────────
RECON_STARTUP_DELAY_SECONDS=15
# Empty = venue bundle default (USD for Kraken, USDT for Binance)
RECON_CURRENCIES=
